<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sejjtech Services | Smart IT Solutions, Simplified</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet" />

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <style>
    :root {
      --primary-color: #0d6efd;
      --secondary-color: #00c9ff;
      --accent-neon: #00ff9d;
      --dark-bg: #020617;
      --dark-bg-soft: #0b1120;
      --light-bg: #f8fafc;
      --text-light: #f9fafb;
      --text-dark: #111827;
    }

    * {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Roboto", sans-serif;
      background-color: #ffffff;
      color: var(--text-dark);
    }

    h1, h2, h3, h4, h5 {
      font-family: "Poppins", sans-serif;
    }

    /* Navbar */
    .navbar-brand {
      font-weight: 700;
      letter-spacing: 1px;
    }

    .nav-link {
      font-weight: 500;
      text-transform: uppercase;
      font-size: 0.9rem;
    }

    .nav-link:hover {
      color: var(--secondary-color) !important;
    }

    /* Hero */
    .hero {
      min-height: 100vh;
      background:
        linear-gradient(135deg, rgba(2, 6, 23, 0.9), rgba(15, 23, 42, 0.9)),
        url("https://images.pexels.com/photos/1181675/pexels-photo-1181675.jpeg?auto=compress&cs=tinysrgb&w=1600") center/cover no-repeat;
      color: var(--text-light);
      display: flex;
      align-items: center;
    }

    .hero h1 {
      font-size: 3rem;
      font-weight: 700;
    }

    .hero p.lead {
      font-size: 1.2rem;
      max-width: 600px;
    }

    .hero .btn-primary {
      background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
      border: none;
      padding: 0.75rem 2rem;
      font-weight: 600;
      border-radius: 999px;
      box-shadow: 0 0 20px rgba(0, 201, 255, 0.5);
    }

    .hero .btn-primary:hover {
      opacity: 0.9;
    }

    .hero .btn-outline-light {
      border-radius: 999px;
      border-width: 2px;
    }

    /* Sections */
    section {
      padding: 80px 0;
    }

    .section-title {
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.9rem;
      color: var(--primary-color);
      font-weight: 600;
    }

    .section-heading {
      font-size: 2rem;
      font-weight: 700;
    }

    /* About */
    .about-text {
      font-size: 1rem;
      line-height: 1.8;
    }

    .counter-box {
      text-align: center;
      padding: 20px;
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .counter {
      font-size: 2rem;
      font-weight: 700;
      color: var(--primary-color);
    }

    .about-image {
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.4);
    }

    /* Services */
    .service-card {
      border: none;
      border-radius: 20px;
      padding: 25px 20px;
      text-align: center;
      background: linear-gradient(135deg, #ffffff, #e0f2fe);
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    .service-card::before {
      content: "";
      position: absolute;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accent-neon), transparent);
      top: -40px;
      right: -40px;
      opacity: 0.3;
    }

    .service-card i {
      font-size: 2.5rem;
      margin-bottom: 15px;
      color: var(--primary-color);
    }

    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.15);
    }

    /* Portfolio */
    .portfolio-item {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      cursor: pointer;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.25);
    }

    .portfolio-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .portfolio-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(13, 110, 253, 0.9),
        rgba(0, 201, 255, 0.9)
      );
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      opacity: 0;
      transition: opacity 0.4s ease;
      padding: 20px;
    }

    .portfolio-item:hover img {
      transform: scale(1.1);
    }

    .portfolio-item:hover .portfolio-overlay {
      opacity: 1;
    }

    /* Testimonials */
    .testimonial-card {
      border-radius: 20px;
      padding: 20px;
      background: #ffffff;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      height: 100%;
    }

    .testimonial-card i {
      color: #fbbf24;
    }

    .avatar-circle {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      color: #ffffff;
      margin-right: 12px;
      font-size: 0.9rem;
    }

    .avatar-blue { background: #2563eb; }
    .avatar-green { background: #16a34a; }
    .avatar-purple { background: #7c3aed; }
    .avatar-orange { background: #ea580c; }
    .avatar-pink { background: #db2777; }

    /* FAQ */
    .faq-item {
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      padding: 20px;
      margin-bottom: 15px;
    }

    /* Pricing */
    .pricing-card {
      border-radius: 20px;
      padding: 30px;
      background: linear-gradient(135deg, #0f172a, #1e293b);
      color: var(--text-light);
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.6);
      position: relative;
      overflow: hidden;
    }

    .pricing-card::before {
      content: "";
      position: absolute;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accent-neon), transparent);
      top: -60px;
      left: -40px;
      opacity: 0.4;
    }

    .pricing-card h4 {
      font-weight: 600;
    }

    /* Tools */
    .tool-badge {
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.6);
      padding: 6px 14px;
      font-size: 0.85rem;
      margin: 4px;
      display: inline-block;
    }

    /* Contact */
    .contact-info p {
      margin-bottom: 8px;
      font-size: 0.95rem;
    }

    .contact-info i {
      color: var(--primary-color);
      margin-right: 8px;
    }

    .map-image {
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.25);
    }

    /* Footer */
    footer {
      background: #020617;
      color: #9ca3af;
      padding: 30px 0;
      font-size: 0.9rem;
    }

    footer a {
      color: #e5e7eb;
      text-decoration: none;
    }

    footer a:hover {
      color: var(--secondary-color);
    }

    /* Dark Mode */
    .dark-mode {
      background-color: var(--dark-bg);
      color: var(--text-light);
    }

    .dark-mode .navbar {
      background-color: #020617 !important;
    }

    .dark-mode section {
      background-color: var(--dark-bg-soft);
    }

    .dark-mode #services,
    .dark-mode #testimonials {
      background-color: #020617;
    }

    .dark-mode .service-card,
    .dark-mode .testimonial-card,
    .dark-mode .counter-box,
    .dark-mode .faq-item {
      background-color: #020617;
      color: var(--text-light);
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.9);
    }

    .dark-mode .pricing-card {
      background: linear-gradient(135deg, #020617, #0f172a);
    }

    .dark-mode footer {
      background-color: #000000;
    }

    .dark-toggle-btn {
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.5);
      padding: 4px 12px;
      font-size: 0.8rem;
      color: #e5e7eb;
      background: transparent;
    }

    .dark-toggle-btn i {
      margin-right: 4px;
    }

    /* Back to top */
    #backToTop {
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 999;
      display: none;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
      color: #ffffff;
      border: none;
      padding: 10px 14px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.6);
    }

    #backToTop i {
      font-size: 1rem;
    }

    @media (max-width: 767.98px) {
      .hero {
        text-align: center;
      }
      .hero h1 {
        font-size: 2.2rem;
      }
      .hero p.lead {
        margin: 0 auto;
      }
    }
  </style>
</head>
